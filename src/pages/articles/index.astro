---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const allArticles = await getCollection('articles');
const sorted = allArticles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="記事一覧" description="FPのひとりごとの全記事一覧です。">
  <div class="mb-6">
    <nav class="text-sm text-gray-500 mb-3">
      <a href={import.meta.env.BASE_URL} class="hover:text-navy-700">ホーム</a>
      <span class="mx-2">/</span>
      <span>記事一覧</span>
    </nav>
    <h1 class="text-2xl font-bold text-navy-800">記事一覧</h1>
    <p class="text-sm text-gray-400 mt-1">全{sorted.length}件</p>
  </div>

  {sorted.length === 0 ? (
    <div class="bg-white rounded-xl border border-gray-200 p-10 text-center text-gray-500">
      <p class="text-4xl mb-3">📰</p>
      <p>記事を準備中です。しばらくお待ちください。</p>
    </div>
  ) : (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {sorted.map((article) => (
        <ArticleCard article={article} />
      ))}
    </div>
  )}
</BaseLayout>
