---
import BaseLayout from './BaseLayout.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { title, pubDate, category, source, sourceUrl, tags, excerpt } = article.data;

const formattedDate = new Intl.DateTimeFormat('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(pubDate);
---

<BaseLayout title={title} description={excerpt}>
  <article class="max-w-3xl mx-auto">

    <!-- パンくずリスト -->
    <nav class="text-sm text-gray-500 mb-4">
      <a href={import.meta.env.BASE_URL} class="hover:text-navy-700">ホーム</a>
      <span class="mx-2">/</span>
      <a href={`${import.meta.env.BASE_URL}category/${category}`} class="hover:text-navy-700">{category}</a>
      <span class="mx-2">/</span>
      <span class="text-gray-700">{title}</span>
    </nav>

    <!-- 記事ヘッダー -->
    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <CategoryBadge category={category} />
        <time class="text-sm text-gray-500" datetime={pubDate.toISOString()}>
          {formattedDate}
        </time>
      </div>
      <h1 class="text-2xl sm:text-3xl font-bold text-navy-800 leading-tight mb-3">
        {title}
      </h1>
      {sourceUrl ? (
        <p class="text-xs text-gray-400 mt-2">
          情報源：<a href={sourceUrl} target="_blank" rel="noopener noreferrer" class="underline hover:text-navy-700">{source}</a>
        </p>
      ) : (
        <p class="text-xs text-gray-400 mt-2">情報源：{source}</p>
      )}
    </header>

    <!-- 記事本文 -->
    <div class="prose prose-navy max-w-none
      prose-headings:text-navy-800
      prose-h1:hidden
      prose-h2:border-b-2 prose-h2:border-navy-100 prose-h2:pb-2
      prose-a:text-navy-600 prose-a:no-underline hover:prose-a:underline
      prose-blockquote:border-l-4 prose-blockquote:border-gold-500 prose-blockquote:bg-yellow-50 prose-blockquote:py-1
      prose-code:text-navy-700 prose-code:bg-gray-100 prose-code:px-1 prose-code:rounded
      prose-strong:text-navy-800">
      <slot />
    </div>

    <!-- タグ -->
    {tags.length > 0 && (
      <div class="mt-8 pt-6 border-t border-gray-200">
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="px-3 py-1 bg-gray-100 text-gray-600 text-sm rounded-full">
              #{tag}
            </span>
          ))}
        </div>
      </div>
    )}

    <!-- ナビゲーション -->
    <div class="mt-8 pt-6 border-t border-gray-200">
      <a href={import.meta.env.BASE_URL} class="inline-flex items-center text-navy-700 hover:text-navy-900 font-medium">
        ← 記事一覧に戻る
      </a>
    </div>

  </article>
</BaseLayout>
